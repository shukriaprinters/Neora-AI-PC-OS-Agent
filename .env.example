# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OPENAI_API_KEY: Required for Whisper speech transcription services.
# Users should populate this via safety secrets configurations in the settings panel.
# Also can configure client-side fallback triggers.
OPENAI_API_KEY=

# GROQ_API_KEY: Optional key for Groq Cloud API Llama/Gemma models.
# Keeps parsing completely free and offline-friendly from paid APIs.
GROQ_API_KEY=

# GITHUB_TOKEN: Optional GitHub Personal Access Token to authenticate commit, pull, push and PR actions.
GITHUB_TOKEN=

# GOOGLE_CLIENT_ID: Client ID for Google Workspace/Drive integration.
GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET: Client Secret for Google Workspace/Drive integration.
GOOGLE_CLIENT_SECRET=

# GOOGLE_DRIVE_FOLDER_ID: Default Google Drive folder ID where uploaded workspace backup files are placed.
GOOGLE_DRIVE_FOLDER_ID=
